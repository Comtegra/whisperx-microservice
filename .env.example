# FFmpeg Microservice v3.0 - Environment Variables
# Copy this file to .env and update the values

# =============================================================================
# REQUIRED
# =============================================================================

# HuggingFace token for PyAnnote model access
# Get your token at: https://huggingface.co/settings/tokens
# You must accept the PyAnnote license at: https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=your_huggingface_token_here

# API authentication token (used for Bearer auth)
APP_TOKEN=your_secure_api_token_here

# =============================================================================
# SERVER SETTINGS (optional)
# =============================================================================

# Enable/disable bearer token authentication (default: true)
# ENABLE_AUTH=true

# Server bind address (default: 0.0.0.0)
# HOST=0.0.0.0

# Server port (default: 8000)
# PORT=8000

# API route prefix (default: /)
# API_PREFIX=/

# =============================================================================
# GPU SETTINGS (optional)
# =============================================================================

# Enable GPU acceleration (default: true)
# USE_GPU=true

# CUDA device index (default: 0)
# GPU_DEVICE=0

# =============================================================================
# WHISPERX SETTINGS (optional)
# =============================================================================

# Model name: tiny, base, small, medium, large-v1, large-v2, large-v3, distil-large-v2
# (default: large-v3)
# WHISPER_MODEL=large-v3

# Default transcription language (default: auto)
# Use ISO 639-1 codes: en, pl, de, fr, es, etc. or "auto" for detection
# WHISPER_LANGUAGE=auto

# Compute type: float16 or int8 (default: float16)
# Use int8 for lower VRAM usage
# WHISPER_COMPUTE_TYPE=float16

# Batch size for transcription (default: 16)
# Lower values use less VRAM
# WHISPER_BATCH_SIZE=16

# Beam size for decoding (default: 5)
# WHISPER_BEAM_SIZE=5

# Sampling temperature (default: 0.0 for deterministic)
# WHISPER_TEMPERATURE=0.0

# Initial prompt for vocabulary/context guidance
# Customize for your domain (e.g., medical, legal, call center)
# WHISPER_INITIAL_PROMPT=

# Enable forced alignment for word-level timestamps (default: true)
# WHISPER_ENABLE_ALIGNMENT=true

# =============================================================================
# PYANNOTE SETTINGS (optional)
# =============================================================================

# PyAnnote diarization model (default: pyannote/speaker-diarization-3.1)
# PYANNOTE_MODEL=pyannote/speaker-diarization-3.1

# =============================================================================
# PROCESSING SETTINGS (optional)
# =============================================================================

# Maximum upload file size in MB (default: 2048)
# MAX_FILE_SIZE_MB=2048

# Temporary file directory (default: /tmp)
# TEMP_DIR=/tmp
